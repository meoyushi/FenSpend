generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Expense {
  id          Int      @id @default(autoincrement())
  requestId   String   @unique
  userEmail   String
  amountCents Int
  category    String
  description String
  date        DateTime
  createdAt   DateTime @default(now())
}